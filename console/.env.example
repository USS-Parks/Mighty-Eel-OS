# Base URLs the console talks to. Defaults target a local dev stack (D1 compose
# sets these for the appliance build). Both are overridable at runtime from the
# login screen, so a prospect can point the shadow-mode console (D2) at their own
# gateway without rebuilding.
VITE_WSF_API_BASE=http://localhost:8081
VITE_AOG_BASE=http://localhost:8080
