# MAI runtime environment variables (.env.example)
#
# This file documents every environment variable the mai-api binary
# and the supporting toolchain actually read. Copy to .env and
# customise. The mai-api binary itself does NOT load a .env file at
# startup — these vars must be exported by your shell, your process
# manager (systemd EnvironmentFile=, kubernetes envFrom:), or your
# container runtime (docker --env-file).
#
# Source of truth for this list is `grep -rE 'env::var' mai-api/`
# and `grep -rE 'os.environ|os.getenv' adapters/` (the Python
# adapters do not consult the environment as of RC1; all adapter
# config flows through the framework).
#
# Last verified against HEAD: 2026-05-24 (DOUGHERTY lane J-04).

# ---------------------------------------------------------------------
# REQUIRED for production
# ---------------------------------------------------------------------

# MAI_SHIP_PROFILE — absolute path to a SHIP profile TOML file.
# Without this, mai-api starts in development mode with permissive
# defaults that are NOT safe for production deployment. The TOML
# schema is defined in mai-api/src/server.rs and the default REST
# port is 8420 (gRPC 8421). The SHIP-03..06 hardening lane uses
# this profile to gate auth, vault, and air-gap enforcement.
MAI_SHIP_PROFILE=

# ---------------------------------------------------------------------
# RECOMMENDED for any environment
# ---------------------------------------------------------------------

# RUST_LOG — log verbosity for the tracing crate.
# Accepted values: error | warn | info | debug | trace.
# Per-module overrides supported, e.g.
#     RUST_LOG=info,mai_api=debug,mai_compliance=trace
# Defaults to error if unset, which is too quiet for production.
RUST_LOG=info

# ---------------------------------------------------------------------
# SDK CONSUMERS ONLY (not the server)
# ---------------------------------------------------------------------

# PYTHONPATH — required only if you are using the mai-sdk-python
# package directly from source rather than from an installed wheel.
# See docs/README-FIRST.md §3 for the developer setup.
# PYTHONPATH=/opt/mai/source/mai-sdk-python/src

# ---------------------------------------------------------------------
# FORWARD-LOOKING (not consumed yet, reserved by the J-06 / J-07
# live-backend integration test sessions)
# ---------------------------------------------------------------------

# OLLAMA_HOST — base URL for a running Ollama instance the live-backend
# integration suite (J-06) will exercise. Set only when running
#     pytest -m live_backend mai/adapters/ollama/tests/test_integration_live.py
# OLLAMA_HOST=http://127.0.0.1:11434

# LLAMACPP_HOST — base URL for a running llama-server (llama.cpp).
# Same semantics as OLLAMA_HOST but for J-07's live suite.
# LLAMACPP_HOST=http://127.0.0.1:8081
