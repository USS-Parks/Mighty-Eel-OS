# Appliance demo defaults are baked into docker-compose.yml; this file documents
# the knobs you can override with `docker compose --env-file` or shell env.
#
# The appliance runs a mock local model by default. To route to real cloud
# providers instead (still shadow-mode governed), set keys on the aog-gateway
# service — it registers openai/anthropic providers when these are non-empty:
#
#   AOG_OPENAI_KEY=sk-...
#   AOG_OPENAI_BASE=https://api.openai.com
#   AOG_ANTHROPIC_KEY=sk-ant-...
#   AOG_ANTHROPIC_BASE=https://api.anthropic.com
#
# Enforcement posture (M1 default is shadow — never blocks):
#   AOG_MODE=shadow          # shadow | report_only | enforce
#
# Host port map (edit in docker-compose.yml): console 8088, aog-gateway 8080,
# wsf-api 8081, openbao 8200.
