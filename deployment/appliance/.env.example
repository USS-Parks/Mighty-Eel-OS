# Appliance DEMO secrets and knobs. Copy to `.env` (gitignored) before bring-up:
#     cp .env.example .env   # then edit the values below
#
# The demo stack is gated behind the `demo` compose profile and only binds to
# the loopback interface. Bring it up with:
#     docker compose --profile demo up --build
#
# ── Required demo secrets (injected; never baked into docker-compose.yml) ──
# The dev OpenBao root token and the WSF AppRole secret. `docker compose` will
# refuse to start if these are unset. Use throwaway values — this is a demo
# trust core (dev mode, in-memory, loopback only), NEVER production.
OPENBAO_DEV_ROOT_TOKEN=change-me-demo-root-token
WSF_OPENBAO_SECRET_ID=change-me-demo-approle-secret

# ── Optional overrides for the reserved data stores ──
# POSTGRES_PASSWORD=wsf-dev
# MINIO_ROOT_PASSWORD=wsf-dev-secret

# ── Route to real cloud providers instead of the mock model (still shadow) ──
# Set keys on the aog-gateway service; it registers providers when non-empty:
#   AOG_OPENAI_KEY=sk-...
#   AOG_OPENAI_BASE=https://api.openai.com
#   AOG_ANTHROPIC_KEY=sk-ant-...
#   AOG_ANTHROPIC_BASE=https://api.anthropic.com
#
# Enforcement posture. The default profile is production and FAILS CLOSED: an
# unset AOG_MODE defaults to enforce, and the non-blocking modes are rejected.
# shadow / report_only require an explicit development profile (as this demo does):
#   AOG_PROFILE=development  # production (default) | development
#   AOG_MODE=shadow          # shadow | report_only | enforce  (defaults to enforce)
#
# Loopback host port map (edit in docker-compose.yml):
#   console 127.0.0.1:8088, aog-gateway 127.0.0.1:8080,
#   wsf-api 127.0.0.1:8081, openbao 127.0.0.1:8200
