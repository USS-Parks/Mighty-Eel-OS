# Copy to `.env` (same directory) and set your key. docker compose reads it
# automatically. Your key never leaves this machine except on the OpenAI calls
# you already make — the gateway custodies it and adds no telemetry.

OPENAI_API_KEY=sk-your-openai-key

# Demo trust-plane secrets (local-only, in-memory dev OpenBao). Any random
# values work — they exist so no credential is ever baked into the compose
# file. Generate, e.g.:  openssl rand -hex 16
OPENBAO_DEV_ROOT_TOKEN=replace-with-random
WSF_OPENBAO_SECRET_ID=replace-with-random

# Optional: an OpenAI-compatible base (Azure OpenAI, a proxy, a local vLLM).
# OPENAI_BASE=https://api.openai.com
