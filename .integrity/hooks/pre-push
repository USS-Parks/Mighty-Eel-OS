#!/usr/bin/env bash
# Canon pre-push (mai) — fast gate: cargo fmt --check + secret scan of the pushed diff.
# clippy/test are deferred to CI (PSPR §0.7) so pushes stay quick. Fail-open on tooling gaps.
set -uo pipefail
cd "$(git rev-parse --show-toplevel 2>/dev/null || echo .)" 2>/dev/null || exit 0
FAIL=0
Z="0000000000000000000000000000000000000000"

if command -v cargo >/dev/null 2>&1; then
  if ! cargo fmt --check >/dev/null 2>&1; then
    echo "BLOCK  workspace is not rustfmt-clean — run cargo fmt before pushing (canon 2.2)." >&2
    FAIL=1
  fi
fi

while read -r _lref loid _rref roid; do
  [ -z "${loid:-}" ] && continue
  [ "$loid" = "$Z" ] && continue
  if [ "${roid:-}" != "$Z" ] && [ -n "${roid:-}" ]; then base="$roid"
  else base="$(git rev-list "$loid" --not --all 2>/dev/null | tail -1)"; [ -n "$base" ] && base="${base}^" || base=""; fi
  if [ -n "$base" ]; then added="$(git diff --unified=0 "$base" "$loid" 2>/dev/null | grep -E '^\+[^+]' || true)"
  else added="$(git show --unified=0 --format= "$loid" 2>/dev/null | grep -E '^\+[^+]' || true)"; fi
  if printf '%s' "$added" | grep -Eq -- '-----BEGIN ([A-Z ]+ )?PRIVATE KEY-----|hv[sb]\.[A-Za-z0-9_-]{20,}'; then
    echo "BLOCK  a pushed commit adds a private key or vault token (canon 1.8)." >&2; FAIL=1
  fi
done

# CANON §11 — full-tree no-slop scan: no build-process artifacts may be pushed.
SLOP_SCAN="$(git rev-parse --show-toplevel)/.integrity/scripts/no-slop-scan.sh"
if [ -x "$SLOP_SCAN" ]; then
  "$SLOP_SCAN" full >&2 || FAIL=1
fi

[ "$FAIL" -eq 0 ] || { echo "pre-push (canon): gate failed." >&2; exit 1; }
exit 0
